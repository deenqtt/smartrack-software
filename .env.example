# ==========================================================
#  SMARTRACK ENVIRONMENT VARIABLES
# ==========================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ==========================================================
#  VERCEL PORTFOLIO DEMO MODE (No DB/MQTT/Redis needed)
# ==========================================================
# Set these 2 variables in Vercel dashboard to enable demo mode
DEMO_MODE="true"
NEXT_PUBLIC_DEMO_MODE="true"
# JWT_SECRET is still required even in demo mode
# JWT_SECRET="smartrack-demo-portfolio-2024"

# ==========================================================
#  1. CORE APP CONFIG
# ==========================================================

# Application environment (development/production)
NODE_ENV="production"
NEXT_PUBLIC_USER_LOGIN_DROPDOWN="true"
# Server port (default: 3030 for production, 3000 for dev)
PORT="3030"
APP_PORT="3030"

# Application name displayed in UI
NEXT_PUBLIC_APP_NAME="Smartrack IOT"

# ==========================================================
#  2. SECURITY & AUTHENTICATION
# ==========================================================

# JWT secret for token signing (generate a strong random string)
# Generate with: openssl rand -hex 32
JWT_SECRET="CHANGE_THIS_VERY_LONG_RANDOM_SECRET_FOR_JWT_TOKENS"

# NextAuth.js configuration (only needed if using NextAuth)
NEXTAUTH_URL="http://localhost:3030"
NEXTAUTH_SECRET="CHANGE_THIS_NEXTAUTH_SECRET_32_CHARS_MINIMUM"

# JWT Expiration time (in seconds)
NEXT_PUBLIC_JWT_EXPIRATION="28800"

# Webhook secret for external integrations
WEBHOOK_SECRET="your-webhook-secret-key"
WEBHOOK_PORT="3001"

# ==========================================================
#  3. MQTT (REAL-TIME COMMUNICATION)
# ==========================================================

# MQTT broker connection settings
NEXT_PUBLIC_MQTT_HOST="localhost"
NEXT_PUBLIC_MQTT_PORT="9000"
NEXT_PUBLIC_MQTT_USERNAME=""
NEXT_PUBLIC_MQTT_PASSWORD=""

# Alternative MQTT broker URL (for WebSocket connections)
MQTT_BROKER_URL="ws://localhost:9000"

# ==========================================================
#  4. CHIRPSTACK (LoRaWAN INTEGRATION)
# ==========================================================

# ChirpStack API endpoint
CHIRPSTACK_API_URL="http://192.168.0.139:8090"

# ChirpStack API token (get from ChirpStack admin panel)
CHIRPSTACK_API_TOKEN="your-chirpstack-api-token-here"

# ==========================================================
#  5. DATABASE (PERSISTENT STORAGE)
# ==========================================================

# PostgreSQL database connection string
# Untuk Docker: gunakan nama container (postgres)
# DATABASE_URL="postgresql://smartrack:smartrack_pass@postgres:5432/smartrack_db?schema=public"

# ==========================================================
#  ACCESS CONTROL (ZKTeco Middleware)
# ==========================================================

# URL middleware Python ZKTeco yang berjalan di host/device
# Server-side (Next.js API routes di dalam Docker): gunakan host.docker.internal
ACCESSCONTROL_API_URL="http://host.docker.internal:8081"

# Client-side (browser): gunakan IP/hostname server yang bisa diakses
# Contoh: http://192.168.0.121:8081
NEXT_PUBLIC_ACCESSCONTROL_API_URL="http://localhost:8081"

# Database credentials
POSTGRES_USER="smartrack"
POSTGRES_PASSWORD="smartrack_pass"
POSTGRES_DB="smartrack_db"

# DATABASE_URL lengkap (Prisma tidak support variable expansion di .env)
DATABASE_URL="postgresql://smartrack:smartrack_pass@localhost:5432/smartrack_db?schema=public"

# ==========================================================
#  6. CACHING & SESSION STORAGE
# ==========================================================

# Redis connection URL for caching and sessions
REDIS_URL="redis://localhost:6379/0"

# ==========================================================
#  7. EXTERNAL APIs & INTEGRATIONS
# ==========================================================

# API keys for external services (add as needed)
OPENWEATHER_API_KEY="your-openweather-api-key"
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
EMAIL_SMTP_HOST="smtp.gmail.com"
EMAIL_SMTP_PORT="587"
EMAIL_SMTP_USER="your-email@gmail.com"
EMAIL_SMTP_PASS="your-email-password"

# ==========================================================
#  8. MONITORING & LOGGING
# ==========================================================

# Log level (ERROR, WARN, INFO, DEBUG)
LOG_LEVEL="INFO"

# Enable bundle analyzer (set to 'true' to analyze bundle size)
ANALYZE="false"

# ==========================================================
#  9. DEVELOPMENT SETTINGS
# ==========================================================

# Enable debug mode (development only)
DEBUG="false"

# Enable hot reload (development only)
HOT_RELOAD="true"

# ==========================================================
#  10. PRODUCTION OPTIMIZATIONS
# ==========================================================

# Enable production optimizations
PRODUCTION_OPTIMIZATIONS="true"

# CDN URL for static assets (optional)
CDN_URL=""

# Enable compression
ENABLE_COMPRESSION="true"

# ==========================================================
#  11. FEATURE FLAGS
# ==========================================================

# Enable/disable specific features
ENABLE_MQTT="true"
ENABLE_CHIRPSTACK="false"
ENABLE_NOTIFICATIONS="true"
ENABLE_BACKUP="true"
ENABLE_LOGGING="true"

# ==========================================================
#  12. BACKUP & MAINTENANCE
# ==========================================================

# Backup directory path
BACKUP_DIR="/home/ubuntu/backups"

# Backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"

# Database backup retention (days)
BACKUP_RETENTION_DAYS="7"

# ==========================================================
#  13. CONTAINER & DEPLOYMENT
# ==========================================================

# Docker container settings
COMPOSE_PROJECT_NAME="smartrack"
DOCKER_BUILDKIT="1"

# Deployment environment
DEPLOY_ENV="production"
DEPLOY_USER="ubuntu"
DEPLOYMENT_DIR="/home/ubuntu/software-smartrack"

# ==========================================================
#  14. SECURITY SETTINGS
# ==========================================================

# CORS allowed origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:3030"

# Rate limiting
RATE_LIMIT_WINDOW="15"
RATE_LIMIT_MAX_REQUESTS="100"

# Session settings
SESSION_TIMEOUT="3600000"  # 1 hour in milliseconds
SESSION_SECURE="true"      # Use HTTPS in production

# ==========================================================
#  15. ADVANCED CONFIGURATION
# ==========================================================

# Custom configuration (JSON format)
CUSTOM_CONFIG="{}"

# Plugin settings
PLUGIN_DIR="./plugins"
ENABLE_PLUGINS="false"

# Performance settings
MAX_WORKERS="4"
MEMORY_LIMIT="1024MB"

# ==========================================================
#  16. LICENSING CONFIGURATION
# ==========================================================

# License Server URL (for online activation)
NEXT_PUBLIC_LICENSE_SERVER_URL="http://54.151.197.127:3300" 

# Shared secrets (HARUS sama dengan Smartrack-Licensing)
# Secret untuk enkripsi license key (AES-256-ECB)
LICENSE_SECRET="807db83011500d66556f1cca62afcb8aec61866bc09a7c59f043b94d10f39fae"
LICENSE_ENCRYPTION_KEY="807db83011500d66556f1cca62afcb8aec61866bc09a7c59f043b94d10f39fae"

# JWT secret untuk activation tokens (HARUS sama dengan Smartrack-Licensing)
JWT_SECRET="your-super-secret-jwt-key"

# Heartbeat interval in hours
HEARTBEAT_INTERVAL_HOURS="24"

# Grace period in days for missed heartbeats
GRACE_PERIOD_DAYS="30"

NEXT_PUBLIC_USER_LOGIN_DROPDOWN="false"

