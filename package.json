{
  "name": "software-smartrack",
  "version": "0.1.0",
  "private": true,
  "sideEffects": [
    "**/*.css",
    "**/*.scss",
    "./app/**/*.css",
    "./components/**/*.css",
    "./lib/**/*.css",
    "./styles/**/*.css",
    "./node_modules/@radix-ui/**/*.css",
    "./node_modules/tailwindcss/**/*.css",
    "./node_modules/maplibre-gl/**/*.css",
    "./node_modules/leaflet/**/*.css"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' next dev -p 3030",
    "dev:fast": "NEXT_PUBLIC_DEV_MODE=fast NODE_OPTIONS='--max-old-space-size=4096 --expose-gc' next dev --turbo -p 3030",
    "dev:analyze": "ANALYZE=true NODE_OPTIONS='--max-old-space-size=1024 --expose-gc' next dev",
    "build": "prisma generate && NODE_OPTIONS='--max-old-space-size=4096' next build",
    "build:debug": "NODE_OPTIONS='--max-old-space-size=6144 --trace-gc --trace-gc-verbose' next build",
    "build:minimal": "NODE_OPTIONS='--max-old-space-size=8192' next build --no-lint",
    "build:diagnostic": "node build-diagnostic.js",
    "build:without-prisma": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "bash -c 'for port in {3000..3100}; do if ! lsof -Pi :$port -sTCP:LISTEN -t >/dev/null 2>&1; then echo \"Starting server on port $port\"; PORT=$port npx next start; fi; done; echo \"No available port found between 3000-3100\"'",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "analyze": "prisma generate && ANALYZE=true npm run build",
    "db:setup": "npx prisma@6.19.2 migrate deploy && npx prisma@6.19.2 generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node scripts/seed-init.js",
    "seed:production": "node scripts/seed-init.js",
    "seed:scada": "node scripts/seed-scada-from-templates.js",
    "fetch:scada": "node scripts/fetch-scada-templates.js",
    "setup:production": "./infrastructure/scripts/setup-production.sh"
  },
